# ===== Frontend production env =====
# Vite automatically reads `.env.production` during `npm run build`.
# 1) Copy this file to `.env.production`
# 2) Set VITE_API_URL to the public URL of your deployed backend (must end in /api)
# 3) Run `npm run build` again, then upload the new dist/ to Hostinger
VITE_API_URL=https://api.your-domain.com/api
